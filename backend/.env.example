# LLM provider configuration.
# The pipeline talks to the LLM through the OpenAI SDK, so ANY OpenAI-compatible
# endpoint works — pick one option below and fill in the key.
OPENAI_API_KEY=your-api-key-here
# MODEL=gpt-4o-mini

# --- Option B: Google Gemini (free tier, OpenAI-compatible gateway) ---
# OPENAI_API_KEY=AIza...your-gemini-key...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# MODEL=gemini-2.5-flash

# --- Optional knobs ---
# TEMPERATURE=0
# MAX_TOKENS=4096
